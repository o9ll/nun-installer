{
	"name": "nun-installer",
	"version": "0.0.1",
	"type": "module",
	"description": "Nun Installer — Electron app with Svelte and Vite",
	"main": "electron/main.cjs",
	"scripts": {
		"dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
		"dev:vite": "vite",
		"dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
		"build:renderer": "vite build",
		"start": "npm run build:renderer && electron .",
		"build": "npm run build:renderer && electron-builder --win portable",
		"build:mac": "npm run build:renderer && electron-builder --mac"
	},
	"dependencies": {
		"gsap": "^3.15.0"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^5.0.1",
		"concurrently": "^9.1.0",
		"cross-env": "^7.0.3",
		"electron": "^33.2.0",
		"electron-builder": "^25.1.8",
		"svelte": "^5.14.1",
		"typescript": "^5.7.2",
		"vite": "^6.0.3",
		"wait-on": "^8.0.1"
	},
	"build": {
		"appId": "com.o9ll.nun",
		"productName": "Nun Installer",
		"directories": {
			"output": "release"
		},
		"files": [
			"electron/**/*",
			"dist/**/*",
			"icon.png"
		],
		"win": {
			"target": "portable",
			"icon": "icon.png"
		},
		"portable": {
			"artifactName": "nun.exe"
		},
		"mac": {
			"target": "dmg",
			"icon": "icon.png",
			"category": "public.app-category.utilities",
			"artifactName": "nun.dmg"
		}
	}
}
